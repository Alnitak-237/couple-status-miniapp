/* components/status-picker/status-picker.wxss */

/* 遮罩层 */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 面板 */
.picker-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 32rpx 28rpx 0;
  animation: slideUp 0.3s ease;
  max-height: 85vh;
  overflow-y: auto;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 标题栏 */
.picker__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.picker__title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.picker__close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

/* 状态网格 */
.picker__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.picker__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: calc((100% - 32rpx) / 3);  /* 3列 */
  background: #F8F8F8;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.picker__item:active {
  transform: scale(0.95);
}

.picker__item--active {
  background: #FFF5F5;
  border-color: var(--primary);
}

.picker__item-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.picker__item-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 自定义状态输入 */
.picker__custom {
  background: #FAFAFA;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.picker__custom-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.picker__custom-row:last-child {
  margin-bottom: 0;
}

.picker__custom-label {
  width: 80rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.picker__custom-input {
  flex: 1;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #EEEEEE;
}

.picker__custom-input--emoji {
  max-width: 120rpx;
}

.picker__custom-error {
  color: #FF4D4F;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 分隔 */
.picker__divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 20rpx 0;
}

/* 心情选择 */
.picker__mood {
  margin-bottom: 24rpx;
}

.picker__mood-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.picker__mood-list {
  display: flex;
  justify-content: space-around;
}

.picker__mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.picker__mood-item--active {
  background: #FFF5F5;
  border-color: var(--primary);
}

.picker__mood-emoji {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.picker__mood-text {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* 底部 */
.picker__footer {
  padding: 16rpx 0 32rpx;
}

.picker__confirm {
  width: 100%;
  border-radius: 48rpx !important;
}
