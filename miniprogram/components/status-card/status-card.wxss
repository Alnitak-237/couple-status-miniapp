/* components/status-card/status-card.wxss */

.status-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 36rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 107, 129, 0.08);
  transition: transform 0.2s ease;
}

.status-card--partner {
  border-left: 6rpx solid var(--primary);
}

.status-card--mine {
  border-left: 6rpx solid #FFB347;
}

.status-card:active {
  transform: scale(0.985);
}

/* 头部 */
.status-card__header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-card__avatar-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.status-card__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.status-card__dot {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #CCCCCC;
  border: 3rpx solid #FFFFFF;
}

.status-card__dot--online {
  background: #52C41A;
}

.status-card__info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.status-card__name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.status-card__time {
  font-size: 24rpx;
}

.status-card__switch-hint {
  flex-shrink: 0;
}

/* 状态主体 */
.status-card__body {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  background: linear-gradient(135deg, #FFF5F5, #FFF0F3);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.status-card__emoji {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.status-card__status-text {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 心情 */
.status-card__mood {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.status-card__mood-emoji {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.status-card__mood-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 操作按钮 */
.status-card__actions {
  display: flex;
  justify-content: center;
}

.status-card__note-btn {
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: #FFFFFF;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.status-card__note-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}
