/* pages/bind/bind.wxss */

.page-bind {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  background: var(--primary-bg);
}

/* 欢迎区 */
.bind__welcome {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.bind__logo {
  font-size: 96rpx;
  display: block;
  margin-bottom: 20rpx;
}

.bind__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.bind__subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* Tab */
.bind__tabs {
  display: flex;
  background: #F0F0F0;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}

.bind__tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 16rpx;
  transition: all 0.2s;
}

.bind__tab--active {
  background: #FFFFFF;
  color: var(--primary);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 标签 */
.bind__label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.bind__desc {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 28rpx;
}

/* 邀请码输入框 */
.bind__code-inputs {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
}

.bind__code-box {
  width: 80rpx;
  height: 96rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  background: #FAFAFA;
  transition: border-color 0.2s;
}

.bind__code-box:focus,
.bind__code-box--filled {
  border-color: var(--primary);
  background: #FFFFFF;
}

/* 邀请码展示 */
.bind__code-display {
  background: linear-gradient(135deg, #FFF5F5, #FFE0E5);
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  margin: 24rpx 0;
}

.bind__code-text {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 12rpx;
  color: var(--primary);
  font-family: 'Courier New', monospace;
}

.bind__expire {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 24rpx;
}

/* 操作按钮 */
.bind__actions {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.bind__actions .btn-outline,
.bind__actions .btn-primary {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
}

/* 错误 */
.bind__error {
  color: #FF4D4F;
  font-size: 24rpx;
  margin-top: 16rpx;
  text-align: center;
}

/* 底部提示 */
.bind__tips {
  margin-top: 60rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bind__tips text {
  font-size: 24rpx;
  color: var(--text-muted);
}
