/* pages/index/index.wxss */

.page-index {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 纪念日栏 */
.anniversary-bar {
  background: linear-gradient(135deg, #FF6B81, #FF8E9E);
  color: #FFFFFF;
  text-align: center;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  margin: 16rpx 48rpx;
}

.divider__line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #FFCCD5, transparent);
}

.divider__text {
  padding: 0 24rpx;
  color: #FF8E9E;
  font-size: 26rpx;
  font-weight: 500;
}

/* 骨架屏卡片 */
.skeleton-card {
  min-height: 280rpx;
}
